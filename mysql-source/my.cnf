# Add this file to the voicebot-application server at:
# ./mysql-source/my.cnf
# And mount it in docker-compose.yml under mysql service:
#   volumes:
#     - ./mysql-source/my.cnf:/etc/mysql/conf.d/source.cnf:ro
# Then restart MySQL once.

[mysqld]
server-id            = 1
log_bin              = mysql-bin
binlog_format        = ROW
binlog_do_db         = voice_assistant
expire_logs_days     = 7

# Slow query log
slow_query_log       = ON
slow_query_log_file  = /var/log/mysql/slow.log
long_query_time      = 1
log_queries_not_using_indexes = ON
