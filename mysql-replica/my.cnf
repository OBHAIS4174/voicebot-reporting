[mysqld]
server-id            = 2
# read_only and super_read_only enabled after replication is confirmed working
relay_log            = relay-bin
log_bin              = mysql-bin
binlog_format        = ROW
gtid_mode            = OFF
replicate_do_db      = voice_assistant

# Slow query log
slow_query_log       = ON
long_query_time      = 1
log_queries_not_using_indexes = ON
